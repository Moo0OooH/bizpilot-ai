{
  "name": "bizpilot-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build",
    "test:unit": "node --test tests/unit/*.test.mts",
    "test:rls": "node --experimental-strip-types tests/rls/run-rls-tests.mts",
    "smoke:public": "node --experimental-strip-types tests/smoke/public-route-smoke.mts",
    "smoke:quote": "node --experimental-strip-types tests/smoke/quote-route-smoke.mts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.13.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
