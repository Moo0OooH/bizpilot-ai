# App - client-safe public values
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase - client-safe public values
NEXT_PUBLIC_SUPABASE_URL=
# Preferred new Supabase public key format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback during migration only
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - server-only privileged key
# Preferred new Supabase secret key format: sb_secret_...
SUPABASE_SECRET_KEY=
# Legacy fallback during migration only
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI - Phase 6 server-only key
OPENAI_API_KEY=

# Email - Phase 7 server-only key
RESEND_API_KEY=

# Stripe - Phase 7 server-only keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Founder-only internal admin allowlist (comma-separated emails)
BIZPILOT_FOUNDER_EMAILS=

# Abuse protection - server-only salt for hashing IP metadata (required in production)
BIZPILOT_IP_HASH_SALT=

# RLS tests - local Postgres/Supabase only, never production
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
